# LLM API Keys (set the one matching your config/settings.yaml provider)
# OpenRouter is the default provider — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Alternative providers (if you change llm.provider in config/settings.yaml)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Data source API keys
FRED_API_KEY=
# Kaggle: place kaggle.json in ~/.kaggle/ instead
